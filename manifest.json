{
    "manifest_version": 3,
    "name": "Dark Pinterest",
    "version": "1.0",
    "description": "A simple dark mode for Pinterest.",
    "permissions": [
      "activeTab"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["*://www.pinterest.com/*"],
        "js": ["content.js"],
        "css": ["styles.css"]
      }
    ]
  }
  